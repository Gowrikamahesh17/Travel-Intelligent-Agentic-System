# ==================== HuggingFace Configuration ====================
HF_TOKEN=your_huggingface_token_here

# ==================== LLM Configuration ====================
# Choose primary LLM provider: "gemini", "openai", or "ollama"
PRIMARY_LLM_PROVIDER=gemini

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-3.5-turbo

# Ollama (local) - no key needed if running locally
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# LLM Settings
LLM_TEMPERATURE=0.7

# ==================== Feature Flags ====================
ENABLE_RAG=true
ENABLE_XAI_VALIDATOR=true
ENABLE_RECOMMENDATIONS=true
USE_MOCK_EMBEDDINGS=false

# ==================== RAG Configuration ====================
# Embeddings provider: "mock", "openai", "huggingface"
EMBEDDINGS_PROVIDER=huggingface
CHROMA_COLLECTION_PREFIX=travel_ai
CHROMA_DB_PATH=./chroma_db

# ==================== Database Configuration ====================
DATABASE_URL=sqlite:///./travel_ai.db
LOG_DATABASE_QUERIES=false

# ==================== API Configuration ====================
API_TIMEOUT=30
API_MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2

# ==================== Logging Configuration ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DIR=./logs

# ==================== Cache Configuration ====================
CACHE_TTL_SECONDS=86400  # 24 hours

# ==================== External APIs ====================
# Weather API
WEATHER_API_KEY=your_weather_api_key
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# Flight/Booking APIs (Mock by default)
BOOKING_API_KEY=your_booking_api_key
HOTEL_API_KEY=your_hotel_api_key

# ==================== Visa & Health APIs ====================
VISA_API_KEY=your_visa_api_key
HEALTH_API_KEY=your_health_api_key

# ==================== Development ====================
DEBUG=false
ENVIRONMENT=production
